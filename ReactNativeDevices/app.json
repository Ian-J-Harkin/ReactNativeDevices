{
  "expo": {
    "name": "SportPlus",
    "slug": "sportplus-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "scheme": "sportplus",
    "plugins": [
      "expo-router",
      [
        "react-native-ble-plx",
        {
          "isBackgroundEnabled": false,
          "modes": [
            "central"
          ],
          "bluetoothAlwaysPermission": "Allow SportPlus to connect to your fitness equipment."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
