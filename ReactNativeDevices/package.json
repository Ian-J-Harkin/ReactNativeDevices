{
  "name": "ble-fitness-bridge",
  "version": "1.0.0",
  "description": "Multi-Protocol BLE Fitness Bridge for React Native",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "prebuild-android": "expo prebuild --platform android --clean",
    "prebuild-ios": "expo prebuild --platform ios --clean",
    "test": "jest --verbose",
    "test:watch": "jest --watchAll --verbose",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@expo/vector-icons": "^14.1.0",
    "@react-native-community/slider": "^5.1.2",
    "@react-navigation/native": "^7.0.14",
    "buffer": "^6.0.3",
    "expo": "^53.0.9",
    "expo-constants": "~17.1.6",
    "expo-font": "~13.3.1",
    "expo-linking": "~7.1.5",
    "expo-router": "~5.0.7",
    "expo-splash-screen": "~0.30.8",
    "expo-status-bar": "~2.2.3",
    "expo-system-ui": "~5.0.7",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "react-native": "0.79.2",
    "react-native-ble-plx": "^3.5.0",
    "react-native-gesture-handler": "~2.24.0",
    "react-native-mmkv": "^2.12.2",
    "react-native-paper": "^5.14.5",
    "react-native-reanimated": "~3.17.4",
    "react-native-safe-area-context": "5.4.0",
    "react-native-screens": "~4.10.0",
    "zod": "^3.23.0",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@types/jest": "^29.5.14",
    "@types/react": "~19.0.10",
    "jest": "^29.7.0",
    "jest-expo": "~53.0.5",
    "ts-jest": "^29.1.0",
    "typescript": "~5.8.3"
  },
  "jest": {
    "preset": "jest-expo",
    "testEnvironment": "node",
    "roots": [
      "<rootDir>/src"
    ],
    "moduleNameMapper": {
      "^react-native-ble-plx$": "<rootDir>/src/services/ble/__tests__/MockBlePeripheral"
    }
  }
}