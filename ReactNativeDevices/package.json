{
  "name": "ble-fitness-bridge",
  "version": "1.0.0",
  "description": "Multi-Protocol BLE Fitness Bridge for React Native",
  "main": "src/services/ble/index.ts",
  "scripts": {
    "test": "jest --verbose",
    "test:watch": "jest --watchAll --verbose",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "react-native-ble-plx": "^3.2.1",
    "zod": "^3.23.0",
    "buffer": "^6.0.3"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "@types/jest": "^29.5.0",
    "@types/react": "^18.2.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.0",
    "react": "^18.2.0",
    "react-native": "^0.74.0"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "roots": ["<rootDir>/src"],
    "moduleNameMapper": {
      "^react-native-ble-plx$": "<rootDir>/src/services/ble/__tests__/MockBlePeripheral"
    }
  }
}
